":"url","match_operation":"contains","negate":false,"pattern":"ProjectTags=79","name":null,"rule_type":null}],"uuid":"6c546d68-2124-4970-aa40-f656e2dc6cc7","invite":{"title":"Your feedback is important to us!","description":"Tell us what you think about this page by taking our quick Survey.","button":"Yes, I will give feedback","close":"No thanks"},"invite_enabled":false,"display_type":"popover","auto_screenshot":true,"etr_enabled":false,"show_legal":false,"logo_path":"surveys/logo/7cde1960dc3f44a3ad918343ac15b44d","button_color":"#1baa64","parent_element_selector":null,"button_survey_label":null,"custom_css":null,"targeting_user_attribute_match_logic":"and"},{"id":956533,"created_epoch_time":1699274028,"skin":"light","background":"#FFFFFF","effective_show_branding":false,"position":"right","content":{"version":2,"questions":[{"uuid":"ec1a3785-0f58-4e41-8235-bed1814fdf73","type":"title-and-description","text":"Do you have any comments or suggestions on our platform? Join the group of Gamefound supporters!","required":true,"description":"We are constantly working on developing new features for our community, and we highly value the input of our users. \n\nBecause of that, we created a group for backers who are willing to share their thoughts and provide feedback on Gamefound. \n\nFor those who have been helping us out in the research and development of the platform, we’ve prepared a dedicated badge – Pathfinder.\n\nJoin us and help us grow!\n","next":"byOrder"},{"uuid":"ddba1e27-df2d-40d8-8495-c6d92ed829ff","type":"email","text":"Leave an email address at which you would like to be contacted at. We won't use it for any marketing purposes; we will contact you to ask for feedback on Gamefound features.","required":true,"next":"byOrder"},{"uuid":"4f69a28c-59bd-46c8-a7de-4d201b51e17a","type":"single-close-ended","text":"I hereby consent to the processing of my personal data that I have provided for the purpose of conducting the UX research for Gamefound.com: https://gamefound.com/terms/privacypolicy","required":true,"randomize_answer_order":false,"pin_last_to_bottom":false,"answers":[{"text":"yes","comments":false},{"text":"no","comments":false}],"nextByAnswer":["byOrder","thankYou"],"next":"byAnswer"},{"uuid":"3789580d-e0d5-4553-941f-811fd10b1bf5","type":"title-and-description","text":"If you have one more minute, please answer 4 more questions and tell us a little bit about yourself.","required":true,"description":"","next":"byOrder"},{"uuid":"809713ed-0b34-4dfe-949b-fd5f6865923d","type":"rating-scale-5","text":"How would you rate your experience with Gamefound so far?","required":false,"nextIfSkipped":"byOrder","scaleCount":5,"labels":[{"text":"Definitely negative"},{"text":"Definitely positive"}],"next":"byOrder"},{"uuid":"2b924a16-6415-40db-a3ef-f32599ba9ac7","type":"single-open-ended-multiple-line","text":"If you could change anything on Gamefound, what would you have us do?","required":false,"nextIfSkipped":"byOrder","next":"byOrder"},{"uuid":"c0fcc783-b5e5-4b71-8c1e-92e39bd170c3","type":"single-close-ended","text":"How many campaigns have you backed on Gamefound?","required":false,"nextIfSkipped":"byOrder","randomize_answer_order":false,"pin_last_to_bottom":false,"answers":[{"text":"1","comments":false},{"text":"up to 3","comments":false},{"text":"up to 10","comments":false},{"text":"more than 10","comments":false}],"next":"byOrder"},{"uuid":"afc0265d-53c0-4a76-a82a-77e1b114576a","type":"multiple-close-ended","text":"What kind of research are you willing to participate in?","required":false,"nextIfSkipped":"byOrder","randomize_answer_order":true,"pin_last_to_bottom":true,"answers":[{"text":"interviews","comments":false},{"text":"user testing","comments":false},{"text":"surveys","comments":false},{"text":"e-mail feedback","comments":false},{"text":"discord discussions","comments":false},{"text":"other","comments":true}],"next":"byOrder"}],"thankyou":"Thank you for your support! We are lucky to have you.\n\nIf you want to par