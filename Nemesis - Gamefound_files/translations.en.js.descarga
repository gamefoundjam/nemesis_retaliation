t.",PasswordChangedSuccessToast:"Your password has been changed.",PasswordFieldLabel:"Password",ProfileCustomizationSectionTitle:"Profile customization",SavedCreditCardInfoText:"Your card information is safely and securely stored by Adyen. Gamefound doesn't store your payment information apart from the type and last four digits of your card number. Saving your card allows to quickly finalize payments on the platform. You won't have to provide card details every time you pay.",SavedCreditCardsSectionTitle:"Saved Card",TwitterFieldDescription:"The address of your Twitter account.",TwitterFieldLabel:"Twitter",TwitterFieldPlaceholder:"https://www.twitter.com/profile",ValidationInvalidSocialLink:"This link is not valid.",YoutubeFieldDescription:"The address of your Youtube account.",YoutubeFieldLabel:"Youtube",YoutubeFieldPlaceholder:"https://www.youtube.com/@channel"},Admin:{CanPostCommentsAsStaffQuirk:"Can post comment as Gamefound staff",CanSkipTwoFactorAuthenticationQuirk:"Can skip two-factor authentication",CompletingDeferredPaymentFailed:"The system was unable to complete the deferred payment.",ExportFormatPlatform:"Gamefound formats",MerchantAccountStatusAdyenFailed:"Adyen - Failed",MerchantAccountStatusAdyenPassed:"Adyen - Passed",MerchantAccountStatusAdyenReview:"In adyen review",MerchantAccountStatusAdyenReviewNeeded:"Adyen - Review needed",MerchantAccountStatusEditing:"In preparation",MerchantAccountStatusFailed:"Rejected",MerchantAccountStatusGamefoundReview:"Waiting for review",MerchantAccountStatusGamefoundReviewNeeded:"Gamefound - Review needed",MerchantAccountStatusVerified:"Verified",NotificationTopicAll:"All",NotificationTopicBlog:"Gamefound Blog",NotificationTopicCommentReply:"Comment replies",NotificationTopicCreatorDigest:"Creator Digest",NotificationTopicCreditBalanceChange:"Credit balance change",NotificationTopicCreditExpirationReminders:"Credit expiration reminders",NotificationTopicFeast:"Gamefound Feast",NotificationTopicNewProjectByCreator:"New projects by creator",NotificationTopicNewsletter:"Newsletter",NotificationTopicPerformanceMarketingDailyReport:"Adfound daily report",NotificationTopicPerformanceMarketingRecommendation:"Adfound recommendation",NotificationTopicPerformanceMarketingSystemMessage:"Adfound system message",NotificationTopicPledgeManagerReminder:"Pledge manager reminder",NotificationTopicProjectMilestones:"Project milestones",NotificationTopicProjectUpdates:"Project updates",NotificationTopicSystemMessages:"System messages",NotificationTopicUserDigest:"Digest frequency",PollTargetAudienceBackers:"Backers",PollTargetAudienceUsers:"Gamefound users",ProjectOnboardingGamefoundKyc:"Gamefound KYC",ProjectOnboardingModeLAdyenHopV2:"Adyen HOP 2.0",ProjectOnboardingModeLegacy:"Legacy Onboarding",ProjectOnboardingModeNone:"None",ProjectOnboardingModeStripeHop:"Stripe HOP",RegisteredVatPayerInLocationWithNoVatReverseEnabledErrorMessage:"Cannot toggle 'Registered VAT payer' setting in a location which does not have Vat Reverse setting enabled.",TermsDocumentScopeAdfoundTermsOfService:"Adfound Terms of Service",TermsDocumentScopeBackersTermsOfService:"Gamefound Terms of Service for Backers",TermsDocumentScopeCommunityGuidelines:"Gamefound Community Guidelines",TermsDocumentScopeContentPolicy:"Gamefound Content Policy",TermsDocumentScopeCreatorsCrowdfundingTermsOfService:"Gamefound Crowdfunding Terms of Service for Creators",TermsDocumentScopeCreatorsDataProcessingAgreement:"Gamefound Data Processing Agreement",TermsDocumentScopeCreatorsDigitalContentTermsOfService:"Gamefound Digital content Terms of Service for Creators",TermsDocumentScopeCreatorsTermsOfService:"Gamefound Terms of Service for Creators",TermsDocumentScopeCrowdfundingTermsOfService:"Gamefound Crowdfunding Terms of Service",TermsDocumentScopeIntellectualPropertyPolicy:"Gamefound IntellectualPropertyPolicy",TermsDocumentScopePrivacyPolicy:"Gamefound Privacy Policy",TermsDocumentScopeReservedFundsPolicy:"Gamefound Reserved Funds Policy",TermsDocumentScopeStoresTermsOfService:"Gamefound Terms of Service for Stores",TermsDocumentScopeTermsOfService:"Gamefound Terms of Service",TermsDocumentScopeTrademarkPolicy:"Gamefound Trademark Policy"},BackerCenter:{ActionRequiredFilterLabel:"Action required",ArchivedProjectsFilterLabel:"Archived projects",ArchiveProjectArchiveStatusLabel:"Move to archive",FailedPaymentsOnlyLabel:"Show failed payments only",HideOrderDetailsLabel:"hide order details",HidePledgeDetailsLabel:"hide pledge details",IncludeArchivedProjectsLabel:"Include archived projects",InstallmentsFilterLabel:"Stretch Pay",InstallmentXOfYLabel:"{0} of {1} installments",NotificationClaimYourGiftActionButton:"Claim your gift",NotificationClaimYourGiftActionLabel:"You can pledge to this project and collect a gift for following the campaign.",NotificationCompletePaymentActionButton:"Complete payment",NotificationCompletePaymentActionLabel:"You haven't finished the payment process for this pledge.",NotificationCompletePledgeActionLabel:"Your shipping address is required to complete your pledge.",NotificationCompleteYourPledgeActionButton:"Complete your pledge",NotificationPendingEditActionButton:"Go to checkout",NotificationPendingEditActionLabel:"You haven't submitted the changes in your pledge.",NotificationStoreCompletePaymentActionLabel:"You haven't finished the payment process for this order.",NotificationStoreUnfinishedCartActionLabel:"You haven't finished your order.",NotificationUnfinishedCartActionButton:"Go to checkout",NotificationUnfinishedCartActionLabel:"You haven't finished your pledge.",NotificationViewYourPledgeActionButton:"View your pledge",NotificationViewYourPledgeActionLabel:"There's been a problem with collecting your installment.",OrderLastModifiedAtLabel:"Last modified",OrderPaidAmountLabel:"Paid amount",OrderPlacedAtLabel:"Placed",PaymentAmountFromFilterLabel:"Payment amount from",PaymentAmountToFilterLabel:"Payment amount to",PaymentDateFromFilterLabel:"Payment date from",PaymentDateToFilterLabel:"Payment date to",PaymentSearchTypeRecentLabel:"Recent",PaymentSearchTypeUpcomingLabel:"Upcoming",PaymentsEmptyStateHeader:"There are no payments to show.",PaymentsEmptyStateParagraph:"Payments related to your orders and pledges will appear here.",PaymentSortByClosestLabel:"Closest in time",PaymentSortByFurthestLabel:"Furthest in time",PaymentStatusFilterLabel:"Payment status",PaymentTypeAllLabel:"All",PaymentTypeFilterLabel:"Payment type",PaymentTypeInstallmentsLabel:"Stretch Pay",PledgeDateFromFilterLabel:"Pledge date from",PledgeDateToFilterLabel:"Pledge date to",PledgeDetailsBoxPledgeInfoText:"Pledge: {0}, placed {1}",PledgeDetailsBoxStoreOrderInfoText:"Order: {0}, placed {1}",PledgesAndOrdersEmptyStateHeader:"There are no pledges to show.",PledgesAndOrdersEmptyStateParagraph:"You'll see your most recent pledges and order changes here.",PledgeStageFilterLabel:"Pledge stage",PledgeValueFromFilterLabel:"Pledge value from",PledgeValueToFilterLabel:"Pledge value to",ProjectArchivedSuccessToast:"Project has been archived.",ProjectInvolvementBackedLabel:"Backed",ProjectInvolvementFollowedLabel:"Followed",ProjectNameFilterLabel:"Project name",ProjectRestoredSuccessToast:"Project has been restored.",RecentlyViewedProjectsEmptyStateHeader:"There are no projects to show.",RecentlyViewedProjectsEmptyStateParagraph:"Look through a few projects — your browsing history will appear here.",RestoreProjectArchiveStatusLabel:"Restore from archive",SearchPhraseFilterLabel:"Search phrase",SearchPhrasePlaceholderLabel:"Type something to search...",SectionPaymentsHeader:"Payments",SectionPledgesAndOrdersHeader:"Pledges & orders",SectionProjectsAllTab:"All",SectionProjectsBackedTab:"Backed",SectionProjectsFollowedTab:"Followed",SectionProjectsHeader:"Your projects",SectionRecentlyViewedProjectsHeader:"Recently viewed projects",SectionRequiresActionHeader:"Action required",SectionUpdatesFeedAllTab:"All",SectionUpdatesFeedBackedTab:"Backed",SectionUpdatesFeedFollowed