            Increasing your spending can help maintain growth and maximize revenue.`};return U===m.High&&(dt.footer=H,dt.highlightClasses="_tc--accent"),Q(dt)},x=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"total cost",value:xe,tooltip:"The total cost of your campaign, including top-ups and fees. The final fee amount will be calculated and displayed at the end of the campaign when the invoice is ready for payment.",enabled:U})},lr=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"paid",value:xe,tooltip:"The total amount of invoices that have already been paid. It's the sum of all payments with the Paid status.",enabled:U})},X=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"to pay",value:xe,tooltip:"The total amount of invoices that await payment. It's the sum of all payments with the Invoiced status.",enabled:U})},ts=(te,ue=!0)=>{const U=u.A.format(te,"P0");return Q({title:"fee rate",value:U,tooltip:"Adfound fee is a percentage of the marketing campaign's actual revenue and will be charged after the campaign ends.",enabled:ue})},ya=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"declared budget",value:xe,tooltip:"This is the planned overall budget for the campaign, used to shape the ad strategy and spending pace throughout the campaign duration.",enabled:U})},it=(te,ue=!0)=>{const U=u.A.format(te,"N0");return Q({title:"impressions",value:U,tooltip:"Total number of times ads were displayed to users.",enabled:ue})},we=(te,ue=!0)=>{const U=u.A.format(te,"N0");return Q({title:"clicks",value:U,tooltip:"Total number of times users clicked on your ads.",enabled:ue})},K=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"balance",value:xe,enabled:U})},gt=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"funds allocated",value:xe,tooltip:"Funds currently assigned to campaigns",enabled:U})},as=(te,ue=!0)=>{const U=u.A.format(te,"N0");return Q({title:"active campaigns",value:U,tooltip:"Campaigns that are live and spending funds",enabled:ue})},Ir=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"total money gross",value:xe,tooltip:"Total amount before  taxes",enabled:U})},cr=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"total money net",value:xe,tooltip:"Total amount after taxes",enabled:U})},Rt=(te,ue,U=!0)=>{const xe=u.A.format((0,c.j)(te),"C2",ue);return Q({title:"credits granted",value:xe,tooltip:"Promotional credits added to your account",enabled:U})},ot="After the top-up, the campaign funds will exceed the declared budget limit. Proceeding will update the budget to prevent unspent funds and adjust the campaign dynamics accordingly. If you do not wish to extend the budget, cancel and modify the top-up amount.",rs={overallSpending:Ne,conversions:Je,costPerFollower:fe,overallRevenue:_a,ROAS:Jt,clicks:we,impressions:it,totalCost:x,paid:lr,toPay:X,feeRate:ts,remainingFunds:de,remainingAddFunds:re,fundsEnoughFor:ve,adfoundFees:he,declaredBudget:ya,balance:K,fundsAllocated:gt,activeCampaigns:as,totalMoneyGross:Ir,totalMoneyNet:cr,creditsGranted:Rt},lt=te=>[{title:"How does Adfound work?",description:"Adfound helps creators grow their crowdfunding campaigns with smarter ads. It connects directly to ad platforms via the Conversion API (CAPI) for accurate tracking and reaches exclusive, high-intent audiences. Bids, audiences, and ad delivery are automatically optimised, so your campaign gains momentum while you focus on your launch.",isCollapsed:!0},{title:"What should my budget be?",description:"Adfound allows campaigns with a budget of minimum 25 EUR per day. Once you input the basic details into the system, it will guide you and suggest appropriate budgets for the phase you\u2019re in. The final decision regarding budget is yours.",isCollapsed:!0},{title:"Is there a spending limit?",description:"We recommend spending as much as makes sense and for as long as it remains profitable. If you\u2019re satisfied with the ROAS (Return On Advertising Spend), consider increasing your investment. If you notice ROAS decreasing, it might be the right time to reduce spending. Always ensure your budget covers at least a few days of campaign activity.",isCollapsed:!0},{title:"How long the campaign should be?",description:"The system allows you to launch a campaign for as little as one hour. However, it is recommended to run the campaign for at least three days to allow the learning phase to complete and optimize performance.",isCollapsed:!0},{title:"Is there a guaranteed ROAS?",description:"Adfound uses a highly refined audience database to ensure your ads reach the right people. However, whether they choose to support your project depends on how appealing your project is to them. For this reason, we cannot guarantee a specific ROAS for your campaign.",isCollapsed:!0},{title:"What do I need to prepare for the campaign?",description:"Provide Adfound with a selection of graphics and text proposals that reflect your project\u2019s vision. Using these assets, Adfound will create optimized ad variations and manage your campaign for you.",isCollapsed:!0},{title:"What if I want to stop the ads, increase the budget, etc.?",description:`<div>You can set spending limits during the initial setup and adjust them at any time.<br><br>
                          You can pause and unpause your ads anytime. Manually pausing the ad will stop its funding.
                          However, spending funds are automatically paused for low-performing assets, so you don't need
                          to worry about doing it yourself.<br><br> If you want to terminate your whole campaign permanently
                          and have your unused funds refunded or transferred to another campaign,
                          <a href="${te}" target="_blank" rel="nofollow noopener noreferrer">
                          contact us</a>.</div>`,isCollapsed:!0},{title:"How much does it cost to work with Adfound?",description:'Adfound fee is 5% of the money the ads bring. You will be charged at the end of your marketing campaign, based on the total revenue generated through Adfound. Campaigns in the "Upcoming" phase are not charged. You can monitor your spending and fees via the dashboard, with data synchronized periodically.',isCollapsed:!0},{title:"How do you determine which funds were brought by Adfound?",description:"For both generating interest and revenue for your project, Adfound uses 7-day click and 1-day view attribution from Meta system.",isCollapsed:!0},{title:"Do I need a business account in Meta?",description:"You don\u2019t need to have Meta account to start running ads with Adfound, your ads will be displayed on our established accounts.",isCollapsed:!0},{title:"Do I need to set up any tracking tools or codes?",description:"You don\u2019t need to connect any tracking codes or tools. Once you launch your campaign, Adfound will handle all the tracking and measurement for you.",isCollapsed:!0},{title:"What are credits and how do they work?",description:"Credits are free funds granted to your business or campaign. You can use them to run ads, but since you didn\u2019t pay for them, they are not included on invoices or in reports that show only your paid and spent money.",isCollapsed:!0}],De=[{title:"Reach the right audience",icon:"users",description:"With years of experience engaging millions of gamers, Adfound guarantees your ads reach the most relevant audience."},{title:"Invest Smarter",icon:"money-bill-trend-up",description:"Adfound constantly optimizes your campaigns, ensuring that funds are allocated only to ads that drive attention and value to your project."},{title:"Save time and effort",icon:"watch",description:"Set up your ads in just a few clicks using an advertising account with a long-standing, trusted reputation."},{title:"Maximize Performance",icon:"analytics",description:"Simply provide your graphics and copy, and Adfound will run automated tests to identify and invest heavily in the highest-performing combinations."},{title:"Maintain control",icon:"sliders-h",description:"Spend only what\u2019s right for your campaign. Pause or boost your ads whenever needed."},{title:"Monitor results",icon:"gauge-max",description:"Track your campaign\u2019s performance with our user-friendly dashboard, offering real-time insights into key metrics."}],Ia=[{title:"Adfound uses platform CAPI",description:" Adfound connects directly to ad platforms via Conversion API (CAPI), ensuring more accurate tracking, better optimisation, and stronger performance than pixel-only setups.",icon:"link"},{title:"Access to exclusive audiences",description:"Adfound campaigns tap into exclusive, high-intent audiences built from years of experience running successful crowdfunding marketing campaigns.",icon:"users"},{title:"Optimisations happen under the hood",description:" Adfound continuously optimises bids, audiences, and delivery in the background, so creators can focus on their launch while performance improves automatically.",icon:"rocket-launch"}],$t=(te,ue)=>{const{managePerformanceMarketingIntegration:U}=projectPermissions;return hasProjectPermissionCurried(te,ue)(U)},ss={add:"add",edit:"edit"},rt={Square:"square",Vertical:"vertical",Horizontal:"horizontal",ShortVertical:"shortVertical"},va={Vertical:"vertical",Square:"square"},Qe={Feeds:"Feeds",StoriesAndReels:"Stories and Reels",RightColumn:"Right column"},Ae={FacebookDesktopRightColumn:"FacebookDesktopRightColumn",FacebookMobileFeed:"FacebookMobileFeed",InstagramMobileFeed:"InstagramMobileFeed",MetaReels:"MetaReels",MetaStories:"MetaStories",LegacyFacebookDesktopRightColumn:"LegacyFacebookDesktopRightColumn"},jt={Stacked:"Stacked",SideBySide:"SideBySide"},vt={horizontalFilename:"horizontalFilename",squareFilename:"squareFilename",verticalFilename:"verticalFilename",shor