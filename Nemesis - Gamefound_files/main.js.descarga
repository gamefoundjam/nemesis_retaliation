                `+e._s(r.description)+`
            `)])])}),0)])},UQ=[];pC._withStripped=!0;const qQ={components:{BaseTitle:U.Od,ModalBox:Fe.A,BaseIcon:U.h_},props:{isVisible:{type:Boolean,default:!1}},computed:{dictionary(){return[{title:"Project",icon:"lightbulb-on",description:"An idea or product a creator is raising funds for. It could be anything from a fresh concept to a polished prototype."},{title:"Creator",icon:"user-crown",description:"The person (or company) behind the campaign, responsible for making the project happen."},{title:"Campaign",icon:"rocket-launch",description:"The journey of promoting and funding a project to bring it to life. Campaigns usually unfold in several stages (more on that soon)."},{title:"Express Crowdfunding",icon:"bolt",description:"A crowdfunding format with no funding goal and instant payments. Backers pay at checkout, and pledges are created immediately. Installments may be available if enabled by the creator, with the first payment charged instantly. Some rewards may be shipped during the campaign, while others are delivered later."},{title:"Following a Project",icon:"heart",description:"Subscribing with your account so you get updates on the project and notifications about future releases from the creator."},{title:"Follower Gift",icon:"award",description:"A little bonus some creators give to fans who follow the project before launch and later back it during the campaign."},{title:"Update",icon:"bullhorn",description:"A post from the creator that shares progress, milestones, or important news with backers and followers."},{title:"Backing",icon:"handshake",description:"Supporting a project financially (also called making a pledge)."},{title:"Pledge",icon:"box-open-full",description:"The amount of money you commit to a project. You\u2019ll usually get to choose from rewards or add-ons offered by the creator."},{title:"Reward",icon:"box",description:"The main item (or bundle) you receive in return for backing, often the project\u2019s star product."},{title:"Add-on",icon:"puzzle",description:"Optional extras you can pick up alongside your main reward. Sometimes these are included within a reward tier."},{title:"Bonus Amount",icon:"hand-holding-dollar",description:"An extra tip or contribution you can add to your pledge via the \u201CShow your support\u201D option."},{title:"Goal (Funding Goal)",icon:"bullseye-arrow",description:"The minimum amount of money needed to make the project a reality. If the goal isn\u2019t met, the campaign fails. If it goes beyond, creators often unlock Stretch Goals."},{title:"Stretch Goal(s)",icon:"unlock",description:"Extra features, upgrades, or goodies unlocked when a campaign surpasses its initial funding target or reaches a set number of backers. Each one comes with its own unlock requirement."},{title:"Stretch Pay",icon:"coin",description:"A free payment plan that lets you split your pledge into installments."},{title:"Deferred Payment",icon:"calendar-day",description:"A \u201Cpay later\u201D option where the money is only charged after the campaign successfully ends. Available for credit cards and PayPal."},{title:"Instant Payment",icon:"credit-card",description:"A payment option that\u2019s charged right away, with no delay."},{title:"Fulfillment",icon:"truck-container",description:"The stage where creators manufacture, pack, and ship rewards to backers."},{title:"Preorder",icon:"cart-shopping",description:"A campaign type for projects that are already finished or nearly ready to go. Unlike crowdfunding, there\u2019s no funding goal \u2013 creators commit to delivering no matter how many people order."},{title:"Store",icon:"store",description:"The straightforward shop part of the platform. Here, creators can sell leftover stock, usually shipping right away. Stores aren\u2019t campaigns and often include multiple items from a creator\u2019s catalog."}]}},methods:{onModalClose(){this.$emit("close")}}};var VQ=(0,C.A)(qQ,pC,UQ,!1,null,null,null);const HQ=VQ.exports,$Q={components:{Box:_e.A,FooterNavigation:Aa,BaseIcon:U.h_,BaseTitle:U.Od,BaseButton:U.SC,TableOfContents:Ts,ThemedImage:ut.A,CrowdfundingGlossaryModal:HQ},data:()=>({isGlossaryVisible:!1}),computed:{platformName(){return c.Ay.platformName},crowdfundingGuideMediaModel(){return[{sectionID:"crowdfunding-is-not-a-store",header:"Crowdfunding is not a store",paragraph:`Backing a project isn't the same as buying something that's already on the shelf.
                            A project is still in development, not a finished, ready-to-ship product.
                            Creators usually offer rewards in return for pledges, but delivery can take time - and in rare cases, may not happen at all.
                            That's why it's important to read the Terms of Service and key sections like Risks and Challenges before pledging.
                            In short: when you pledge, you're supporting an idea that may or may not become reality.`,image:"/content/images/static/crowdfunding/not-a-shop.svg",isReversed:!1}]},stages(){return[{sectionID:"upcoming",header:"Upcoming",paragraph:"A sneak peek of the campaign before launch. You can follow the project here to stay in the loop. Some creators also offer a special Follower Gift if you follow early and later back during the campaign.",image:"/content/images/static/crowdfunding/drafting.svg",isReversed:!0},{sectionID:"crowdfunding",header:"Crowdfunding",paragraph:`<p>The big launch. This is when pledges are collected, stretch goals can be unlocked, and the project really takes shape. Campaigns usually run for a limited time and appear publicly on Gamefound for the community to support.</p>
                                <p>Depending on the funding mode chosen by the creator, crowdfunding can work in slightly different ways:</p>
                                <ul>
                                    <li>Standard crowdfunding uses a funding goal. Payments are collected only if the campaign ends successfully, and backers can freely edit or cancel their pledges during the campaign.</li>
                                    <li>Express crowdfunding has no funding goal and uses instant payments. Pledges are created at checkout, and some rewards may be shipped while the campaign is still running.</li>
                                </ul>
                                <p>In both cases, crowdfunding is about supporting a project before it is fully realized and helping shape its final form through stretch goals, updates, and community feedback.</p>`,image:"/content/images/static/crowdfunding/rocket.svg",isReversed:!1},{sectionID:"latePledge",header:"Late Pledge",paragraph:"A chance to jump in after the main campaign closes. Rewards might be limited or a bit pricier here, and pledges no longer count toward Stretch Goals. Follower Gifts, if offered, also don't apply anymore.",image:"/content/images/static/crowdfunding/lp.svg",isReversed:!0},{sectionID:"pledgeManager",header:"Pledge Manager",paragraph:`The stage where shipping details and fees are collected. 
                                Creators may still offer items here, though availability can vary. Depending on the setup, 
                                a Pledge Manager can be: 
                                Fully open (new pledges and edits allowed),
                                Partially open (only some backers can make changes),
                                Shipping-only (addresses only, no new pledges),
                                Closed (no changes possible).
                            `,image:"/content/images/static/crowdfunding/pm.svg",isReversed:!1}]},stepsExplanationModel(){return[{sectionID:"refunds",icon:"undo",iconNamespace:"fa",header:"Refunds and Responsibility",paragraph:`
                            Not every campaign goes exactly as planned. Sometimes products take longer, look different than expected, or, in rare cases, don't make it to the finish line. Usually this isn't because of bad intentions - it's simply part of supporting early-stage innovation.
                            We carefully review creators to minimize risks and ensure campaigns are launched in good faith - but some uncertainty will always remain. As a platform, we provide the tools and space for creators to raise funds, but we're not a storefront. Refunds, product quality, and fulfillment are the creator's responsibility.
                            Before pledging, always check the project's Refunds and Cancellations section to understand the policy. And if you're unsure about anything, don't hesitate to reach out to the creator directly.
                        `},{sectionID:"risks",icon:"dice",iconNamespace:"fa",header:"Risks of Crowdfunding",paragraph:`
                            Crowdfunding is exciting, but it's different from shopping in a store. Rewards don't arrive right after pledging, and delivery dates are estimates, not guarantees. Manufacturing, logistics, or unexpected challenges can cause delays - or even change the final product.
                            Remember: the creator is fully responsible for their project. If you ever have questions or doubts, the best way to get answers is by contacting the creator directly. The platform helps connect creators and backers, but it doesn't control how funds are used once they're transferred. After a successful campaign, the creator receives the money and is in charge of delivering on their promises.
                        `}]}},methods:{buildPageAnchors(a){Object.keys(a).forEach(e=>{const t=this.$refs[e]instanceof Array?this.$refs[e][0]:this.$refs[e],r=t.textContent,l=!0;new Kt(t,r,t.id,l)})},onGlossaryClose(){this.isGlossaryVisible=!1},onGlossaryOpen(){this.isGlossaryVisible=!0}},mounted(){this.buildPageAnchors(this.$refs)}};var zQ=(0,C.A)($Q,uC,EQ,!1,null,null,null);const WQ=zQ.exports;var mC=function(){var e=this,t=e._self._c;return t("base-view",{staticClass:"gfu-blog"},[t("main",{staticClass:"gfu-layout__main gfu-layout__main--extranarrow js-main-content"},[e.hasItems?t("div",{staticClass:"col-12"},[e._l(e.pagedItems,function(r){return t("blog-post-details-card",{key:r.urlName,staticClass:"mb-4",attrs:{"blog-post":r,"is-preview":""}})}),e._v(" "),e.isMoreVisible?t("div",{staticClass:"_flex _jc-c _mt-3"},[t("processing-button",{attrs:{theme:"outline","is-processing":e.isProcessing},on:{click:e.onMore}},[e._v(`
