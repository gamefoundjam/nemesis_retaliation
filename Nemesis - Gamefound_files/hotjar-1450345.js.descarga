 duplicated or overlapping ","comments":false},{"text":"other","comments":true}],"next":"byOrder"}],"thankyou":"Want to test our improved navigation? \n\nTake a look at what we’ve prepared and tell us what you think.\nhttps://app.lyssna.com/do/15n2hff6efku/urio1k"},"connect_visit_data":"always","ask_for_consent":false,"language":"en","display_condition":"immediate","display_delay":0,"persist_condition":"once","targeting_percentage":100,"targeting":[{"component":"url","match_operation":"contains","negate":false,"pattern":"admin","name":null,"rule_type":null},{"component":"device","match_operation":"exact","negate":false,"pattern":"desktop","name":null,"rule_type":null}],"uuid":"c20f4db0-3f45-40e3-af08-950b04030bba","invite":{"title":"Your feedback is important to us!","description":"Tell us what you think about this page by taking our quick Survey.","button":"Yes, I will give feedback","close":"No thanks"},"invite_enabled":false,"display_type":"popover","auto_screenshot":true,"etr_enabled":false,"show_legal":false,"logo_path":"surveys/logo/6f8e64e0b54a4697bfe094df89330e6c","button_color":"#1baa64","parent_element_selector":null,"button_survey_label":null,"custom_css":null,"targeting_user_attribute_match_logic":"and"},{"id":1849078,"created_epoch_time":1773049773,"skin":"light","background":"#FFFFFF","effective_show_branding":false,"position":"right","content":{"version":2,"questions":[{"uuid":"9638b8ae-2bb7-42ea-b888-625bc7548877","type":"title-and-description","text":"Improve your ad experience","required":true,"description":"Help us customize ad suggestions for you","next":"byOrder"},{"uuid":"676a263b-5cc6-428c-bd24-54c8a8605c2f","type":"single-close-ended","text":"Have you used the AI copy suggestions when creating your ad?","required":true,"randomize_answer_order":false,"pin_last_to_bottom":false,"answers":[{"text":"yes","comments":false},{"text":"no","comments":false},{"text":"I haven't noticed them","comments":false}],"nextByAnswer":["question:ebf1fecf-5461-4747-aabe-1766fa1748aa","question:9f24e6b0-fdb3-4fe7-a132-091df7212a64","question:65afe2f9-8f59-4813-963b-a7824878cd69"],"next":"byAnswer"},{"uuid":"ebf1fecf-5461-4747-aabe-1766fa1748aa","type":"single-close-ended","text":"How helpful were the AI copy suggestions?","required":true,"randomize_answer_order":false,"pin_last_to_bottom":false,"answers":[{"text":"Very helpful","comments":false},{"text":"Somewhat helpful","comments":false},{"text":"Hard to tell","comments":false},{"text":"Rather not helpful","comments":false},{"text":"Not helpful at all","comments":false},{"text":"I haven't noticed them","comments":false}],"nextByAnswer":["question:65afe2f9-8f59-4813-963b-a7824878cd69","question:65afe2f9-8f59-4813-963b-a7824878cd69","question:9f24e6b0-fdb3-4fe7-a132-091df7212a64","question:9f24e6b0-fdb3-4fe7-a132-091df7212a64","question:9f24e6b0-fdb3-4fe7-a132-091df7212a64","byOrder"],"next":"byAnswer"},{"uuid":"9f24e6b0-fdb3-4fe7-a132-091df7212a64","type":"single-close-ended","text":"What was the main reason?","required":true,"randomize_answer_order":true,"pin_last_to_bottom":true,"answers":[{"text":"I prefer writing my own copy.","comments":false},{"text":"Suggestions felt generic.","comments":false},{"text":"Suggestions were not aligned with my brand voice.","comments":false},{"text":"I don't trust AI-generated copy.","comments":false},{"text":"It took too long to review/edit.","comments":false},{"text":"I use another AI tool instead.","comments":false},{"text":"I haven't noticed them.","comments":false},{"text":"other","comments":true}],"nextByAnswer":["byOrder","byOrder","byOrder","question:77816bce-7703-4d43-818d-42f9c3dc67fc","byOrder","question:94c58ddd-3704-4dad-9673-ac26c173e093","question:65afe2f9-8f59-4813-963b-a7824878cd69","byOrder"],"next":"byAnswer"},{"uuid":"809020a1-843a-4292-b9fa-7464b9ecfb27","type":"single-open-ended-multiple-line","text":"What could we do to make copy suggestions more helpful for you?  ","required":false,"nextIfSkipped":"byOrder","next":"byOrder"},{"uuid":"65afe2f9-8f59-4813-963b-a7824878cd69","type":"single-close-ended","text":"Do you use other AI tools to write ad copy?","required":true,"randomize_answer_order":false,"pin_last_to_bottom":false,"answers":[{"text":"Yes, almost always","comments":false},{"text":"Frequently","comments":false},{"text":"Sometimes","comments":false},{"text":"Rarely","comments":false},{"text":"Never","comments":false}],"nextByAnswer":["question:94c58ddd-3704-4dad-9673-ac26c173e093","question:94c58ddd-3704-4dad-9673-ac26c173e093","question:94c58ddd-3704-4dad-9673-ac26c173e093","question:a49ab199-0115-46ea-9169-b5aeb99a8fad","question:a49ab199-0115-46ea-9169-b5aeb99a8fad"],"next":"byAnswer"},{"uuid":"a49ab199-0115-46ea-9169-b5aeb99a8fad","type":"multiple-close-ended","text":"Why don’t you usually use AI tools to write your ad copy?","required":true,"randomize_answer_order":true,"pin_last_to_bottom":true,"answers":[{"text":"I don’t trust AI-generated copy to sound authentic.","comments":false},{"text":"AI copy doesn’t match my brand voice.","comments":false},{"text":"AI suggestions felt generic or low-quality.","comments":false},{"text":"I’m not familiar with AI tools / unsure how to use them.","comments":false},{"text":"I’m concerned about data privacy.","comments":false},{"text":"other","comments":true}],"next":"question:77816bce-7703-4d43-818d-42f9c3dc67fc"},{"uuid":"77816bce-7703-4d43-818d-42f9c3dc67fc","type":"single-open-ended-multiple-line","text":"What’s your current process for writing ad copy?","required":false,"nextIfSkipped":"question:4a1dd6eb-a2ac-4bae-af21-c0afe4b60eb4","next":"byOrder"},{"uuid":"94c58ddd-3704-4dad-9673-ac26c173e093","type":"single-open-ended-multiple-line","text":"Which AI tools are you using for ad copy?","required":false,"nextIfSkipped":"byOrder","next":"byOrder"},{"uuid":"4a1dd6eb-a2ac-4bae-af21-c0afe4b60eb4","type":"single-open-ended-multiple-line","text":"Is there anything else you would like to share about AI suggestions on Adfound? Fee